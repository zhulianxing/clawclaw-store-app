<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/app_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_bg"
    android:clickable="true"
    android:focusable="true">

    <!-- 图标 -->
    <TextView
        android:id="@+id/app_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:text="📦"
        android:textSize="32sp"
        android:gravity="center"
        android:background="@drawable/icon_bg"
        android:layout_marginEnd="16dp" />

    <!-- 信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/app_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="APP名称"
                android:textColor="#F8F8FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 链上"
                android:textColor="#10B981"
                android:textSize="11sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/app_pkg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="com.example.app"
            android:textColor="#707088"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/app_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="应用描述"
            android:textColor="#B0B0C0"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/app_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 USDC"
                android:textColor="#06B6D4"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_dev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="创作者: 0x1Bcb...7004"
                android:textColor="#707088"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
